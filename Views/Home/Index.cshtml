@{
    ViewData["Title"] = "Welcome";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">Welcome to Demo Project Website</h3>
            </div>
            <div class="card-body">
                <p class="lead">
                    This site is <strong>for testing purposes only</strong>.
                    Please do not enter real or sensitive information.
                </p>
                <p>
                    Explore the features, try out forms, and navigate through pages to see how the site behaves.
                </p>
                <hr />
                <p>
                    For demonstration, you can visit:
                </p>
                <ul>
                    <li><a asp-controller="Contact" asp-action="Index">Contact Page</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Page</a></li>
                </ul>
            </div>
            <div class="card-footer text-muted text-center">
                &copy; @DateTime.Now.Year - Demo Project Website
            </div>
        </div>
    </div>
</div>
